{
  "info": {
    "name": "ClinicFlow API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api" },
    { "key": "admin_token", "value": "" },
    { "key": "doctor_token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('admin_token', json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@clinic.com\",\n  \"password\": \"admin123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login as Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) pm.collectionVariables.set('doctor_token', json.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"dr.smith@clinic.com\",\n  \"password\": \"doctor123\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login - Invalid Credentials",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"wrong@clinic.com\",\n  \"password\": \"wrongpass\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Appointments",
      "item": [
        {
          "name": "Get Doctors List (Admin only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{admin_token}}" }],
            "url": { "raw": "{{base_url}}/appointments/doctors", "host": ["{{base_url}}"], "path": ["appointments", "doctors"] }
          }
        },
        {
          "name": "Create Appointment (Admin only)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientName\": \"Jane Doe\",\n  \"doctorId\": \"REPLACE_WITH_DOCTOR_ID\",\n  \"date\": \"2026-04-25\",\n  \"startTime\": \"10:00\",\n  \"duration\": 30\n}"
            },
            "url": { "raw": "{{base_url}}/appointments", "host": ["{{base_url}}"], "path": ["appointments"] }
          }
        },
        {
          "name": "Create Appointment - Validation Error (past date)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientName\": \"J\",\n  \"doctorId\": \"invalid\",\n  \"date\": \"2020-01-01\",\n  \"startTime\": \"10:00\",\n  \"duration\": 30\n}"
            },
            "url": { "raw": "{{base_url}}/appointments", "host": ["{{base_url}}"], "path": ["appointments"] }
          }
        },
        {
          "name": "Get My Appointments - Today (Doctor only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{doctor_token}}" }],
            "url": { "raw": "{{base_url}}/appointments/my", "host": ["{{base_url}}"], "path": ["appointments", "my"] }
          }
        },
        {
          "name": "Get My Appointments - No Token (should 401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/appointments/my", "host": ["{{base_url}}"], "path": ["appointments", "my"] }
          }
        },
        {
          "name": "Doctor tries to create appointment (should 403)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{doctor_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientName\": \"Test\",\n  \"doctorId\": \"someid\",\n  \"date\": \"2026-04-25\",\n  \"startTime\": \"10:00\",\n  \"duration\": 30\n}"
            },
            "url": { "raw": "{{base_url}}/appointments", "host": ["{{base_url}}"], "path": ["appointments"] }
          }
        }
      ]
    }
  ]
}
